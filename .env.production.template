# ╔══════════════════════════════════════════════════════════════════╗
# ║  MedFlow — Variáveis de Ambiente (Produção)                    ║
# ║  Copie para .env.production e preencha os valores              ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://medflow:CHANGE_ME@postgres:5432/medflow
POSTGRES_DB=medflow
POSTGRES_USER=medflow
POSTGRES_PASSWORD=CHANGE_ME

# ── Autenticação (gere com: openssl rand -base64 64) ─────────────
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# ── Criptografia PII (gere com: openssl rand -hex 32) ────────────
ENCRYPTION_KEY=CHANGE_ME

# ── OpenAI (agente IA) ───────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Sentry (monitoramento de erros) ──────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...
SENTRY_ORG=your-org
SENTRY_PROJECT=medflow
# SENTRY_AUTH_TOKEN=sntrys_... (para upload de source maps)

# ── Billing (Asaas) ────────────────────────────────────────────────
ASAAS_API_KEY=CHANGE_ME
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=CHANGE_ME

# ── Email (Resend) ─────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=MedFlow <noreply@medflow.com.br>

# ── Analytics (PostHog) ──────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Backup S3 ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
S3_BACKUP_BUCKET=medflow-backups
AWS_DEFAULT_REGION=sa-east-1

# ── Aplicação ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.medflow.com.br
NODE_ENV=production
LOG_LEVEL=info
